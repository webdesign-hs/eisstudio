#!/bin/bash

# Zeit-Tracking für Eisstudio Projekt
# Verwendung: tt [start|pause|stop|status|log]

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TRACK_FILE="$SCRIPT_DIR/.timetrack"
LOG_FILE="$SCRIPT_DIR/timetrack.log"

# Farben
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

format_time() {
    local total_seconds=$1
    local hours=$((total_seconds / 3600))
    local minutes=$(((total_seconds % 3600) / 60))
    local seconds=$((total_seconds % 60))
    printf "%02d:%02d:%02d" $hours $minutes $seconds
}

start_tracking() {
    if [ -f "$TRACK_FILE" ]; then
        source "$TRACK_FILE"
        if [ "$STATUS" = "running" ]; then
            echo -e "${YELLOW}⏱  Läuft bereits!${NC}"
            return
        fi
    fi

    local now=$(date +%s)
    local accumulated=${ACCUMULATED:-0}

    echo "START_TIME=$now" > "$TRACK_FILE"
    echo "STATUS=running" >> "$TRACK_FILE"
    echo "ACCUMULATED=$accumulated" >> "$TRACK_FILE"
    echo "SESSION_START=$(date '+%Y-%m-%d %H:%M:%S')" >> "$TRACK_FILE"

    echo -e "${GREEN}▶  Gestartet${NC}"
    [ $accumulated -gt 0 ] && echo -e "${BLUE}   Bisher: $(format_time $accumulated)${NC}"
}

pause_tracking() {
    if [ ! -f "$TRACK_FILE" ]; then
        echo -e "${RED}✗  Kein Timer aktiv${NC}"
        return
    fi

    source "$TRACK_FILE"

    if [ "$STATUS" = "paused" ]; then
        echo -e "${YELLOW}⏸  Bereits pausiert: $(format_time $ACCUMULATED)${NC}"
        return
    fi

    local now=$(date +%s)
    local session_time=$((now - START_TIME))
    local total=$((ACCUMULATED + session_time))

    echo "START_TIME=$START_TIME" > "$TRACK_FILE"
    echo "STATUS=paused" >> "$TRACK_FILE"
    echo "ACCUMULATED=$total" >> "$TRACK_FILE"
    echo "SESSION_START=$SESSION_START" >> "$TRACK_FILE"

    echo -e "${YELLOW}⏸  Pausiert: $(format_time $total)${NC}"
}

stop_tracking() {
    if [ ! -f "$TRACK_FILE" ]; then
        echo -e "${RED}✗  Kein Timer aktiv${NC}"
        return
    fi

    source "$TRACK_FILE"

    local now=$(date +%s)
    local total=$ACCUMULATED

    [ "$STATUS" = "running" ] && total=$((ACCUMULATED + now - START_TIME))

    echo "$(date '+%Y-%m-%d %H:%M:%S') | $(format_time $total) | Start: $SESSION_START" >> "$LOG_FILE"

    echo -e "${RED}⏹  Gestoppt: $(format_time $total)${NC}"
    rm "$TRACK_FILE"
}

show_status() {
    if [ ! -f "$TRACK_FILE" ]; then
        echo -e "${BLUE}ℹ  Kein Timer aktiv${NC}"
        return
    fi

    source "$TRACK_FILE"

    local now=$(date +%s)
    local current_total=$ACCUMULATED

    if [ "$STATUS" = "running" ]; then
        current_total=$((ACCUMULATED + now - START_TIME))
        echo -e "${GREEN}▶  Läuft: $(format_time $current_total)${NC}"
    else
        echo -e "${YELLOW}⏸  Pausiert: $(format_time $current_total)${NC}"
    fi
}

show_log() {
    if [ ! -f "$LOG_FILE" ]; then
        echo -e "${BLUE}ℹ  Keine Einträge${NC}"
        return
    fi

    echo ""
    cat "$LOG_FILE"
    echo ""

    local total_seconds=0
    while IFS= read -r line; do
        time_str=$(echo "$line" | grep -oE '[0-9]{2}:[0-9]{2}:[0-9]{2}' | head -1)
        if [ -n "$time_str" ]; then
            hours=$(echo "$time_str" | cut -d: -f1 | sed 's/^0//')
            minutes=$(echo "$time_str" | cut -d: -f2 | sed 's/^0//')
            seconds=$(echo "$time_str" | cut -d: -f3 | sed 's/^0//')
            total_seconds=$((total_seconds + hours*3600 + minutes*60 + seconds))
        fi
    done < "$LOG_FILE"

    echo -e "${GREEN}GESAMT: $(format_time $total_seconds)${NC}"
}

case "$1" in
    start)   start_tracking ;;
    pause)   pause_tracking ;;
    stop)    stop_tracking ;;
    status)  show_status ;;
    log)     show_log ;;
    *)
        echo "tt start  - Timer starten"
        echo "tt pause  - Pausieren"
        echo "tt stop   - Stoppen & speichern"
        echo "tt status - Status anzeigen"
        echo "tt log    - Alle Zeiten anzeigen"
        ;;
esac
